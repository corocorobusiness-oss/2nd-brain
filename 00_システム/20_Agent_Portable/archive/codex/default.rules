prefix_rule(pattern=["rg", "-o", ".{0,120}(x-client|clientInfo|ClientInfo|X-Platform|X-App|appVersion|client-version|Mercari).{0,120}"], decision="allow")
prefix_rule(pattern=["rg", "-o", ".{0,120}(client|Client|version|Version|platform|Platform|api\\.mercari|api).{0,120}"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "urls=$(curl -L --max-time 20 -s 'https://jp.mercari.com/search?keyword=test' | rg -o 'https://web-jp-assets-v2\\.mercdn\\.net/_next/static/[^\" ]+\\.js' | sort -u); for u in $urls; do h=$(curl -L --max-time 20 -s \"$u\" | rg -o '\"/[^\"]{0,120}\"' | rg '(/v[0-9]/|entities|search)' | head -20); if [ -n \"$h\" ]; then echo \"URL $u\"; echo \"$h\"; fi; done"], decision="allow")
prefix_rule(pattern=["rg", "-o", "\"/[^\"]{0,160}\""], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "for u in $(curl -L --max-time 20 -s 'https://jp.mercari.com/search?keyword=test' | rg -o 'https://web-jp-assets-v2\\.mercdn\\.net/_next/static/[^\" ]+\\.js' | sort -u); do if curl -L --max-time 20 -s \"$u\" | rg -q '4536:'; then echo $u; fi; done"], decision="allow")
prefix_rule(pattern=["rg", "-o", ".{0,180}(4536:|entities|search|item|price|on_sale|status|useHttp|api|params|pageToken|hasMore).{0,180}"], decision="allow")
