prefix_rule(pattern=["/bin/zsh", "-lc", "for u in $(curl -L --max-time 20 -s 'https://jp.mercari.com/search?keyword=test' | rg -o 'https://web-jp-assets-v2\\.mercdn\\.net/_next/static/[^\" ]+\\.js' | sort -u); do if curl -L --max-time 20 -s \"$u\" | rg -q '73658:'; then echo $u; fi; done"], decision="allow")
