prefix_rule(pattern=["curl"], decision="allow")
prefix_rule(pattern=["head", "-80"], decision="allow")
prefix_rule(pattern=["rg", "-o", "https://web-jp-assets-v2\\.mercdn\\.net/_next/static/[^\" ]+\\.js"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "urls=$(curl -L --max-time 20 -s 'https://jp.mercari.com/search?keyword=test' | rg -o 'https://web-jp-assets-v2\\.mercdn\\.net/_next/static/[^\" ]+\\.js' | sort -u); for u in $urls; do h=$(curl -L --max-time 20 -s \"$u\" | rg -o '.{0,120}(api\\.mercari|mercari-platform|entities:search|search/items|items/search|itemSearch|searchCondition|items:get|item:get).{0,120}' | head -5); if [ -n \"$h\" ]; then echo \"URL $u\"; echo \"$h\"; fi; done"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "urls=$(curl -L --max-time 20 -s 'https://jp.mercari.com/search?keyword=test' | rg -o 'https://web-jp-assets-v2\\.mercdn\\.net/_next/static/[^\" ]+\\.js' | sort -u); for u in $urls; do h=$(curl -L --max-time 20 -s \"$u\" | rg -o '.{0,140}(searchCondition|SearchCondition|search/items|items/search|graphql|api|searchSessionId|priceMax|status|onSale|itemIds|itemList).{0,140}' | head -8); if [ -n \"$h\" ]; then echo \"URL $u\"; echo \"$h\"; fi; done"], decision="allow")
prefix_rule(pattern=["rg", "-o", ".{0,140}(searchCondition|SearchCondition|search/items|items/search|graphql|api|searchSessionId|priceMax|status|onSale|itemIds|itemList).{0,140}"], decision="allow")
